generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id        String    @id @default(cuid())
  token     String    @unique
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Service {
  id                 String              @id @default(cuid())
  slug               String              @unique
  nameTr             String
  nameEn             String
  descriptionTr      String              @db.Text
  descriptionEn      String              @db.Text
  shortDescTr        String
  shortDescEn        String
  iconName           String              @default("tooth")
  durationMinutes    Int                 @default(30)
  order              Int                 @default(0)
  isActive           Boolean             @default(true)
  imageUrl           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  specialistServices SpecialistService[]
  appointments       Appointment[]
}

model Specialist {
  id                 String              @id @default(cuid())
  slug               String              @unique
  nameTr             String
  nameEn             String
  titleTr            String
  titleEn            String
  biographyTr        String              @db.Text
  biographyEn        String              @db.Text
  photoUrl           String              @default("")
  order              Int                 @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  specialistServices SpecialistService[]
  appointments       Appointment[]
  workingHours       WorkingHour[]
  blockedSlots       BlockedSlot[]
}

model SpecialistService {
  id           String     @id @default(cuid())
  specialistId String
  serviceId    String
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  service      Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([specialistId, serviceId])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PatientLanguage {
  TR
  EN
}

model Appointment {
  id              String            @id @default(cuid())
  serviceId       String
  specialistId    String
  service         Service           @relation(fields: [serviceId], references: [id])
  specialist      Specialist        @relation(fields: [specialistId], references: [id])
  date            DateTime          @db.Date
  startTime       String
  endTime         String
  patientName     String
  patientPhone    String
  patientEmail    String            @default("")
  patientNote     String            @default("") @db.Text
  patientLanguage PatientLanguage   @default(TR)
  status          AppointmentStatus @default(PENDING)
  adminNote       String            @default("") @db.Text
  smsSent         Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  smsLogs         SmsLog[]
}

model WorkingHour {
  id           String     @id @default(cuid())
  specialistId String
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotMinutes  Int        @default(30)
  isOpen       Boolean    @default(true)

  @@unique([specialistId, dayOfWeek])
}

model BlockedSlot {
  id           String     @id @default(cuid())
  specialistId String
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  startTime    String
  endTime      String
  reason       String     @default("")
  createdAt    DateTime   @default(now())
}

model Review {
  id          String   @id @default(cuid())
  patientName String
  ratingStars Int
  contentTr   String   @db.Text
  contentEn   String   @db.Text
  isApproved  Boolean  @default(false)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQItem {
  id         String   @id @default(cuid())
  questionTr String
  questionEn String
  answerTr   String   @db.Text
  answerEn   String   @db.Text
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String   @default("")
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum SmsType {
  CONFIRMATION
  REMINDER
  CANCELLATION
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

model SmsLog {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  phone         String
  message       String      @db.Text
  type          SmsType
  status        SmsStatus   @default(PENDING)
  providerRef   String      @default("")
  errorMessage  String      @default("")
  createdAt     DateTime    @default(now())
}
